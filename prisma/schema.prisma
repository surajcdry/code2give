// Local development workflow:
//   - Generate client: `npx prisma generate`
//   - Create & apply a new migration to your *local/dev* DB: `npx prisma migrate dev --name <message>`
// For Supabase / remote (e.g. prod) environments, apply existing migrations with: `npx prisma migrate deploy`
// To update this schema from an existing Supabase database, use: `npx prisma db pull`

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Stakeholder {
  id        String   @id @default(cuid())
  role      Role     @default(DONOR)
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resource {
  id                     String      @id
  name                   String?
  description            String?
  description_es         String?
  addressStreet1         String?
  addressStreet2         String?
  city                   String?
  state                  String?
  zipCode                String?
  latitude               Float?
  longitude              Float?
  timezone               String?
  website                String?
  resourceTypeId         String?
  resourceTypeName       String?
  resourceStatusId       String?
  openByAppointment      Boolean     @default(false)
  appointmentRequired    Boolean     @default(false)
  acceptingNewClients    Boolean     @default(true)
  confidence             Float?
  ratingAverage          Float?
  waitTimeMinutesAverage Float?
  reviewCount            Int         @default(0)
  subscriberCount        Int         @default(0)
  priority               Int?
  mergedToResourceId     String?
  contacts               Json        @default("[]")
  images                 Json        @default("[]")
  shifts                 Json        @default("[]")
  occurrences            Json        @default("[]")
  occurrenceSkipRanges   Json        @default("[]")
  tags                   Json        @default("[]")
  regionsServed          Json        @default("[]")
  resourceSlugs          Json        @default("[]")
  syncedAt               DateTime    @default(now())
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  feedback               Feedback[]
  tractId                String?
  gnnScore               Float?
  archetypeId            Int?
  archetypeName          String?
}

model Feedback {
  id              String    @id @default(cuid())
  text            String
  sentiment       String?
  tags            String[]
  resourceId      String?
  resource        Resource? @relation(fields: [resourceId], references: [id])
  waitTimeMinutes Int?
  rating          Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Pantry {
  id          String   @id @default(cuid())
  name        String
  location    String?
  latitude    Float
  longitude   Float
  hours       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CensusData {
  id           String   @id @default(cuid())
  tractId      String   @unique
  povertyIndex Float
  population   Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Role {
  DONOR
  GOV
  ADMIN
}
